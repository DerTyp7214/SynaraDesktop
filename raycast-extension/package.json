{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "synara",
  "title": "Synara",
  "description": "Control Synara and search for music.",
  "icon": "icon.png",
  "author": "dertyp",
  "license": "MIT",
  "categories": [
    "Media"
  ],
  "commands": [
    {
      "name": "search",
      "title": "Search Music",
      "subtitle": "Search Synara",
      "description": "Search for songs, albums, artists and playlists.",
      "mode": "view"
    },
    {
      "name": "now-playing",
      "title": "Now Playing",
      "subtitle": "Currently playing song",
      "description": "Show current song and lyrics.",
      "mode": "view"
    },
    {
      "name": "queue",
      "title": "View Queue",
      "subtitle": "Upcoming tracks",
      "description": "Show upcoming songs.",
      "mode": "view"
    }
  ],
  "preferences": [
    {
      "name": "defaultSearchAction",
      "type": "dropdown",
      "required": false,
      "title": "Default Search Action",
      "description": "The action to perform when pressing Enter on a search result.",
      "defaultValue": "play",
      "data": [
        { "title": "Play", "value": "play" },
        { "title": "Play Next", "value": "playNext" },
        { "title": "Add to Queue", "value": "addToQueue" }
      ]
    },
    {
      "name": "defaultQueueAction",
      "type": "dropdown",
      "required": false,
      "title": "Default Queue Action",
      "description": "The action to perform when pressing Enter on a queue item.",
      "defaultValue": "play",
      "data": [
        { "title": "Play at Position", "value": "play" },
        { "title": "Play Next", "value": "playNext" },
        { "title": "Add to Queue", "value": "addToQueue" }
      ]
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.65.0",
    "@raycast/utils": "^2.2.3",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.1.1",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "eslint": "^10.2.0",
    "prettier": "^3.0.3",
    "typescript": "^6.0.3"
  },
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "npx @raycast/api@latest publish"
  }
}
