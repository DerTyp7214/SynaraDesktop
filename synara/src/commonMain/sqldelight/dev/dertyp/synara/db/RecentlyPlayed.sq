CREATE TABLE IF NOT EXISTS RecentlyPlayedSongEntity (
    userId TEXT NOT NULL,
    id TEXT NOT NULL,
    timestamp INTEGER NOT NULL,
    payload TEXT NOT NULL,
    PRIMARY KEY (userId, id)
);

CREATE TABLE IF NOT EXISTS RecentlyPlayedAlbumEntity (
    userId TEXT NOT NULL,
    id TEXT NOT NULL,
    timestamp INTEGER NOT NULL,
    payload TEXT NOT NULL,
    PRIMARY KEY (userId, id)
);

CREATE TABLE IF NOT EXISTS RecentlyPlayedArtistEntity (
    userId TEXT NOT NULL,
    id TEXT NOT NULL,
    timestamp INTEGER NOT NULL,
    payload TEXT NOT NULL,
    PRIMARY KEY (userId, id)
);

insertSong:
INSERT OR REPLACE INTO RecentlyPlayedSongEntity(userId, id, timestamp, payload)
VALUES (?, ?, ?, ?);

insertAlbum:
INSERT OR REPLACE INTO RecentlyPlayedAlbumEntity(userId, id, timestamp, payload)
VALUES (?, ?, ?, ?);

insertArtist:
INSERT OR REPLACE INTO RecentlyPlayedArtistEntity(userId, id, timestamp, payload)
VALUES (?, ?, ?, ?);

getSongs:
SELECT * FROM RecentlyPlayedSongEntity WHERE userId = ? ORDER BY timestamp DESC LIMIT ?;

getAlbums:
SELECT * FROM RecentlyPlayedAlbumEntity WHERE userId = ? ORDER BY timestamp DESC LIMIT ?;

getArtists:
SELECT * FROM RecentlyPlayedArtistEntity WHERE userId = ? ORDER BY timestamp DESC LIMIT ?;

deleteAllSongs:
DELETE FROM RecentlyPlayedSongEntity WHERE userId = ?;

deleteAllAlbums:
DELETE FROM RecentlyPlayedAlbumEntity WHERE userId = ?;

deleteAllArtists:
DELETE FROM RecentlyPlayedArtistEntity WHERE userId = ?;

migrateUserId:
UPDATE RecentlyPlayedSongEntity SET userId = ? WHERE userId = '';

migrateAlbumUserId:
UPDATE RecentlyPlayedAlbumEntity SET userId = ? WHERE userId = '';

migrateArtistUserId:
UPDATE RecentlyPlayedArtistEntity SET userId = ? WHERE userId = '';
