CREATE TABLE IF NOT EXISTS RecentlyPlayedSongEntity (
    id TEXT PRIMARY KEY,
    timestamp INTEGER NOT NULL,
    payload TEXT NOT NULL
);

CREATE TABLE IF NOT EXISTS RecentlyPlayedAlbumEntity (
    id TEXT PRIMARY KEY,
    timestamp INTEGER NOT NULL,
    payload TEXT NOT NULL
);

CREATE TABLE IF NOT EXISTS RecentlyPlayedArtistEntity (
    id TEXT PRIMARY KEY,
    timestamp INTEGER NOT NULL,
    payload TEXT NOT NULL
);

CREATE TRIGGER IF NOT EXISTS prune_songs_trigger AFTER INSERT ON RecentlyPlayedSongEntity
BEGIN
    DELETE FROM RecentlyPlayedSongEntity
    WHERE id NOT IN (
        SELECT id FROM RecentlyPlayedSongEntity
        ORDER BY timestamp DESC
        LIMIT 100
    );
END;

CREATE TRIGGER IF NOT EXISTS prune_albums_trigger AFTER INSERT ON RecentlyPlayedAlbumEntity
BEGIN
    DELETE FROM RecentlyPlayedAlbumEntity
    WHERE id NOT IN (
        SELECT id FROM RecentlyPlayedAlbumEntity
        ORDER BY timestamp DESC
        LIMIT 100
    );
END;

CREATE TRIGGER IF NOT EXISTS prune_artists_trigger AFTER INSERT ON RecentlyPlayedArtistEntity
BEGIN
    DELETE FROM RecentlyPlayedArtistEntity
    WHERE id NOT IN (
        SELECT id FROM RecentlyPlayedArtistEntity
        ORDER BY timestamp DESC
        LIMIT 100
    );
END;

insertSong:
INSERT OR REPLACE INTO RecentlyPlayedSongEntity(id, timestamp, payload)
VALUES (?, ?, ?);

insertAlbum:
INSERT OR REPLACE INTO RecentlyPlayedAlbumEntity(id, timestamp, payload)
VALUES (?, ?, ?);

insertArtist:
INSERT OR REPLACE INTO RecentlyPlayedArtistEntity(id, timestamp, payload)
VALUES (?, ?, ?);

getSongs:
SELECT * FROM RecentlyPlayedSongEntity ORDER BY timestamp DESC LIMIT ?;

getAlbums:
SELECT * FROM RecentlyPlayedAlbumEntity ORDER BY timestamp DESC LIMIT ?;

getArtists:
SELECT * FROM RecentlyPlayedArtistEntity ORDER BY timestamp DESC LIMIT ?;

deleteAllSongs:
DELETE FROM RecentlyPlayedSongEntity;

deleteAllAlbums:
DELETE FROM RecentlyPlayedAlbumEntity;

deleteAllArtists:
DELETE FROM RecentlyPlayedArtistEntity;
